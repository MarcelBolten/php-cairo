--TEST--
CairoWin32Fontface::__construct() function
--SKIPIF--
<?php
include __DIR__ . '/../../skipif.inc';
if (!class_exists('\Cairo\FontFace\Win32'))
	die('skip - Cairo\FontFace\Win32 class not available');
